{
  "manifest_version": 3,
  "name": "Prolific Telegram Alerts",
  "description": "Get instant Telegram notifications when new paid studies appear on Prolific.",
  "version": "1.2.3",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.prolific.com/*",
    "https://app.prolific.com/*",
    "https://api.telegram.org/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.prolific.com/*", "https://app.prolific.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*test-page*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "32": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon128.png",
    "32": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  }
}
